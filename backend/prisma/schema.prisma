// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =======================
// ROLES
// =======================
model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())

  users           User[]
  rolePermissions RolePermission[]
}

// =======================
// USERS
// =======================
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())

  roleId Int
  role   Role @relation(fields: [roleId], references: [id])

  @@index([roleId])
}

// =======================
// PERMISSIONS
// =======================
model Permission {
  id          Int              @id @default(autoincrement())
  module      String
  operation   String
  description String?
  createdAt   DateTime         @default(now())

  rolePermissions RolePermission[]

  @@unique([module, operation])
}

// =======================
// ROLE - PERMISSION (JOIN TABLE)
// =======================
model RolePermission {
  roleId       Int
  permissionId Int

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// =======================
// CLIENTS
// =======================
model Client {
  id                Int      @id @default(autoincrement())
  name              String
  phone             String
  email             String
  company           String?
  address           String?
  notes             String?
  subscriptionStart DateTime
  subscriptionEnd   DateTime
  createdAt         DateTime @default(now())

  devices    Device[]
  deviceSets DeviceSet[]

  @@index([subscriptionEnd])
}

// =======================
// DEVICES
// =======================
model Device {
  id              Int      @id @default(autoincrement())
  code            String   @unique // e.g., ATV-001, ITV-005, TAB-012
  barcode         String   @unique
  type            String   // 'tv', 'tablet', 'stand', 'istand', 'mediaBox', 'battery', 'fabrication'
  brand           String?
  size            String?
  model           String?
  color           String?
  gpsId           String?
  mfgDate         DateTime?
  healthStatus    String   @default("ok")
  lifecycleStatus String   @default("warehouse") // 'warehouse', 'assigning', 'deployed'
  location        String?  // For warehouse: "Warehouse A", For deployed: will be linked to deployment location
  state           String?  // For deployed devices
  district        String?  // For deployed devices
  pinpoint        String?  // Specific location name
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Foreign key to client (nullable because device may not be assigned)
  clientId        Int?
  client          Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  // Optional: device can belong to a set
  setId           Int?
  deviceSet       DeviceSet? @relation(fields: [setId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([lifecycleStatus])
  @@index([clientId])
  @@index([code])
  @@index([barcode])
  @@index([setId])
}

// =======================
// DEVICE SETS
// =======================
model DeviceSet {
  id              Int      @id @default(autoincrement())
  code            String   @unique  // e.g. ASET-001, ISET-002, TSET-003
  barcode         String   @unique
  setType         String   // 'aStand', 'iStand', 'tabletCombo', or custom key
  setTypeName     String   // human readable e.g. 'A-Frame Standee', 'Tent Card Set'
  name            String?  // optional custom name
  lifecycleStatus String   @default("warehouse") // 'warehouse', 'in_transit', 'deployed'
  healthStatus    String   @default("ok")         // 'ok', 'repair', 'damage'
  location        String?
  state           String?
  district        String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clientId        Int?
  client          Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  components      Device[]

  @@index([setType])
  @@index([lifecycleStatus])
  @@index([clientId])
  @@index([barcode])
}
