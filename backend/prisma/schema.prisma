generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  description     String?
  createdAt       DateTime         @default(now())
  rolePermissions RolePermission[]
  users           User[]
}

model User {
  id               Int                @id @default(autoincrement())
  name             String
  email            String             @unique
  password         String
  status           String             @default("ACTIVE")
  createdAt        DateTime           @default(now())
  roleId           Int
  requestsApproved LifecycleRequest[] @relation("ApprovedBy")
  requestsMade     LifecycleRequest[] @relation("RequestedBy")
  notifications    Notification[]
  role             Role               @relation(fields: [roleId], references: [id])

  @@index([roleId])
}

model Permission {
  id              Int              @id @default(autoincrement())
  module          String
  operation       String
  description     String?
  createdAt       DateTime         @default(now())
  rolePermissions RolePermission[]

  @@unique([module, operation])
}

model RolePermission {
  roleId       Int
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Client {
  id                Int                @id @default(autoincrement())
  name              String
  phone             String
  email             String
  company           String?
  address           String?
  notes             String?
  createdAt         DateTime           @default(now())
  devices           Device[]
  deviceSets        DeviceSet[]
  lifecycleRequests LifecycleRequest[]
}

model Device {
  id                Int                @id @default(autoincrement())
  code              String             @unique
  type              String
  brand             String?
  size              String?
  model             String?
  color             String?
  gpsId             String?
  mfgDate           DateTime?
  lifecycleStatus   String             @default("available")
  location          String?
  state             String?
  district          String?
  pinpoint          String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  clientId          Int?
  healthStatus      String             @default("ok")
  setId             Int?
  approvedAt        DateTime?
  approvedById      Int?
  assignedAt        DateTime?
  barcode           String             @unique
  deployedAt        DateTime?
  subscriptionEndDate DateTime?
  rejectionNote     String?
  requestedAt       DateTime?
  requestedById     Int?
  client            Client?            @relation(fields: [clientId], references: [id])
  deviceSet         DeviceSet?         @relation(fields: [setId], references: [id])
  history           DeviceHistory[]
  lifecycleRequests LifecycleRequest[] @relation("DeviceRequests")

  @@index([type])
  @@index([lifecycleStatus])
  @@index([clientId])
  @@index([code])
  @@index([barcode])
  @@index([setId])
}

model DeviceSet {
  id                Int                @id @default(autoincrement())
  code              String             @unique
  barcode           String             @unique
  setType           String
  setTypeName       String
  name              String?
  lifecycleStatus   String             @default("available")
  healthStatus      String             @default("ok")
  location          String?
  state             String?
  district          String?
  notes             String?
  clientId          Int?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  approvedAt        DateTime?
  approvedById      Int?
  rejectionNote     String?
  requestedAt       DateTime?
  requestedById     Int?
  subscriptionEndDate DateTime?
  components        Device[]
  client            Client?            @relation(fields: [clientId], references: [id])
  lifecycleRequests LifecycleRequest[] @relation("SetRequests")

  @@index([setType])
  @@index([lifecycleStatus])
  @@index([clientId])
  @@index([barcode])
}

model LifecycleRequest {
  id            Int        @id @default(autoincrement())
  deviceId      Int?
  setId         Int?
  clientId      Int?
  fromStep      String
  toStep        String
  healthStatus  String     @default("ok")
  healthNote    String?
  note          String?
  requestedById Int
  createdAt     DateTime   @default(now())
  approvedById  Int?
  approvedAt    DateTime?
  status        String     @default("pending")
  rejectionNote String?
  autoApproved  Boolean    @default(false)
  approvedBy    User?      @relation("ApprovedBy", fields: [approvedById], references: [id])
  client        Client?    @relation(fields: [clientId], references: [id])
  device        Device?    @relation("DeviceRequests", fields: [deviceId], references: [id])
  requestedBy   User       @relation("RequestedBy", fields: [requestedById], references: [id])
  deviceSet     DeviceSet? @relation("SetRequests", fields: [setId], references: [id])
  proofFiles    ProofFile[]

  @@index([status])
  @@index([deviceId])
  @@index([setId])
  @@index([clientId])
  @@index([requestedById])
  @@index([toStep])
  @@index([createdAt])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  body      String
  requestId Int?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
}

model DeviceHistory {
  id          Int      @id @default(autoincrement())
  deviceId    Int
  fromStatus  String
  toStatus    String
  changedById Int?
  changedAt   DateTime @default(now())
  note        String?
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@index([deviceId, changedAt])
}

model AssignmentRequest {
  id                 Int       @id @default(autoincrement())
  requestType        String
  deviceId           Int?
  setId              Int?
  clientId           Int
  healthStatus       String    @default("ok")
  healthComment      String?
  returnType         String
  returnDays         Int?
  returnMonths       Int?
  returnDate         DateTime?
  computedReturnDate DateTime?
  status             String    @default("pending")
  requestedBy        Int?
  approvedBy         Int?
  approvedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([status])
  @@index([clientId])
  @@index([deviceId])
  @@index([setId])
}

model TeamRequest {
  id            Int                  @id @default(autoincrement())
  requestedById Int
  deviceId      Int?
  setId         Int?
  requestType   String
  changes       Json
  status        String               @default("pending")
  note          String?
  adminNote     String?
  approvedById  Int?
  approvedAt    DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  comments      TeamRequestComment[]

  @@index([status])
  @@index([requestedById])
  @@index([deviceId])
  @@index([setId])
}

model TeamRequestComment {
  id            Int         @id @default(autoincrement())
  teamRequestId Int
  authorId      Int
  authorRole    String
  message       String
  createdAt     DateTime    @default(now())
  authorName    String
  teamRequest   TeamRequest @relation(fields: [teamRequestId], references: [id], onDelete: Cascade)

  @@index([teamRequestId])
}

model ProofFile {
  id          Int              @id @default(autoincrement())
  requestId   Int
  fileName    String           // original filename
  storedName  String           // uuid-based name on disk / storage key
  fileType    String           // 'image' | 'video' | 'pdf'
  mimeType    String
  sizeKb      Int
  url         String           // public URL (local path or CDN URL)
  thumbUrl    String?          // compressed thumbnail URL (images only)
  createdAt   DateTime         @default(now())
  request     LifecycleRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model SubscriptionReminder {
  id           Int       @id @default(autoincrement())
  deviceId     Int?
  setId        Int?
  reminderDate DateTime  @default(now())
  reminderType String    // "7day" | "2day" | "expired"
  sent         Boolean   @default(false)
  sentAt       DateTime?
  attended     Boolean   @default(false)
  attendedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([deviceId])
  @@index([setId])
  @@index([attended])
  @@unique([deviceId, reminderType], name: "unique_device_reminder")
  @@unique([setId, reminderType],    name: "unique_set_reminder")
}
