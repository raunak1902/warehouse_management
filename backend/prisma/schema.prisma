// CatalogueLocationPreset
// Named specific-location presets (e.g. "Rack 5", "Shelf 3") that appear as
// autocomplete chips inside WarehouseLocationSelector.

// ─────────────────────────────────────────────────────────────────────────────
// CatalogueLocationPreset
// Named specific-location presets (e.g. "Rack 5", "Shelf 3") that appear as
// autocomplete chips inside WarehouseLocationSelector.
// ─────────────────────────────────────────────────────────────────────────────

model CatalogueLocationPreset {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([isActive])
}
