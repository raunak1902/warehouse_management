# =========================
# DATABASE CONFIG
# =========================
# NOTE: @ in password is encoded as %40
# Example: password "my@pass" becomes "my%40pass"
DATABASE_URL="postgresql://username:password@hostname:5432/database_name"

# Production example with connection pooling:
# DATABASE_URL="postgresql://produser:securepassword@production-db.example.com:5432/edsignage?schema=public&connection_limit=20"

# =========================
# AUTH / SECURITY
# =========================
# Generate a strong random secret using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_minimum_32_characters_long

# =========================
# SYSTEM INITIALIZATION (SUPER ADMIN)
# =========================
# These credentials are used to create the initial SuperAdmin account
# CRITICAL: Change these values for production!
# CRITICAL: Change the password immediately after first login!
SUPERADMIN_EMAIL=admin@yourdomain.com
SUPERADMIN_PASSWORD=YourStrongPasswordHere!MinimumLength12Chars
SUPERADMIN_NAME=Super Administrator

# =========================
# SERVER CONFIGURATION
# =========================
NODE_ENV=development
PORT=5000

# =========================
# CORS CONFIGURATION
# =========================
# Comma-separated list of allowed origins (no spaces)
# Development example:
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:3000

# Production example:
# ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com,https://admin.yourdomain.com

# =========================
# OPTIONAL: MONITORING & LOGGING
# =========================
# LOG_LEVEL=info
# SENTRY_DSN=your_sentry_dsn_for_error_tracking
# ENABLE_REQUEST_LOGGING=false

# Email (Resend - https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx